{
  "$schema": "https://swc.rs/schema.json",
  "module": {
    "type": "es6",
    "resolveFully": true
  },
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true
    },
    "transform": {
      "react": {
        "runtime": "classic"
      }
    },
    "target": "es2020",
    "baseUrl": "src"
  }
}
